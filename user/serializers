class RegisterSerializer(serializers.ModelSerializer):
    class Meta:
        model = User
        fields = ("username", "password", "email")

    def create(self, validated_data):
        user = User.objects.create_user(
            username=validated_data["username"],
            email=validated_data.get("email"),
            password=validated_data["password"],
            is_active=False
        )

        confirmation = UserConfirmation.objects.create(user=user)
        confirmation.generate_code()

    
        print("CONFIRM CODE:", confirmation.code)

        return user
    
class LoginSerializer(serializers.Serializer):
    username = serializers.CharField()
    password = serializers.CharField()

    def validate(self, data):
        user = authenticate(**data)

        if not user:
            raise serializers.ValidationError("Invalid credentials")

        if not user.is_active:
            raise serializers.ValidationError("User is not confirmed")

        token, _ = Token.objects.get_or_create(user=user)

        return {
            "token": token.key
        }    
    
    
class ConfirmUserSerializer(serializers.Serializer):
    username = serializers.CharField()
    code = serializers.CharField(max_length=6)

    def validate(self, data):
        try:
            user = User.objects.get(username=data["username"])
        except User.DoesNotExist:
            raise serializers.ValidationError("User not found")

        try:
            confirmation = user.confirmation
        except UserConfirmation.DoesNotExist:
            raise serializers.ValidationError("No confirmation code")

        if confirmation.code != data["code"]:
            raise serializers.ValidationError("Wrong code")

        user.is_active = True
        user.save()

        confirmation.delete()

       
        return {"status": "user confirmed"}
    


